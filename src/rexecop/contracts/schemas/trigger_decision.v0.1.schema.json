{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sclite.dev/trigger_decision.v0.1.schema.json",
  "title": "SCLite Trigger Decision v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "schema_ref",
    "decision_id",
    "decision",
    "reason",
    "decided_at",
    "source",
    "event",
    "rule_set",
    "rule",
    "admission",
    "operation_ref",
    "authority"
  ],
  "properties": {
    "artifact_type": {"const": "trigger_decision"},
    "schema_version": {"const": "v0.1"},
    "schema_ref": {"const": "schemas/trigger_decision.v0.1.schema.json"},
    "decision_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "decision": {
      "enum": ["plan_operation", "ignore", "escalate", "drop_duplicate", "cooldown_blocked"]
    },
    "reason": {"type": "string", "minLength": 1, "maxLength": 512},
    "decided_at": {"type": "string", "minLength": 1, "maxLength": 64},
    "source": {"type": "string", "minLength": 1, "maxLength": 128},
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source",
        "type",
        "subject",
        "occurred_at",
        "digest",
        "payload_digest",
        "dedupe_key",
        "cooldown_key"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 128},
        "source": {"type": "string", "minLength": 1, "maxLength": 128},
        "type": {"type": "string", "minLength": 1, "maxLength": 128},
        "subject": {"type": "string", "minLength": 1, "maxLength": 256},
        "occurred_at": {"type": "string", "minLength": 1, "maxLength": 64},
        "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "payload_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "dedupe_key": {"type": "string", "minLength": 1, "maxLength": 512},
        "cooldown_key": {"type": ["string", "null"], "maxLength": 512}
      }
    },
    "rule_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 128},
        "version": {"type": "string", "minLength": 1, "maxLength": 64},
        "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "rule": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["id", "digest"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 128},
        "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "admission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_digest", "admission_digest", "allowed", "outcome"],
      "properties": {
        "request_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "admission_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "allowed": {"type": "boolean"},
        "outcome": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    },
    "operation_ref": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["operation_id"],
      "properties": {
        "operation_id": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truth_layer",
        "planner",
        "policy_authority",
        "domain_authority",
        "execution_authority"
      ],
      "properties": {
        "truth_layer": {"const": "sclite"},
        "planner": {"const": "rexecop"},
        "policy_authority": {"const": "govengine"},
        "domain_authority": {"type": "string", "minLength": 1, "maxLength": 128},
        "execution_authority": {"const": "rexecop"}
      }
    }
  }
}
