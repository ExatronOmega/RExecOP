{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sclite.dev/watchdog_decision.v0.1.schema.json",
  "title": "SCLite Watchdog Decision v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "schema_ref",
    "decision_id",
    "decision",
    "reason",
    "decided_at",
    "source",
    "observation",
    "admission",
    "affected",
    "authority",
    "non_claims"
  ],
  "properties": {
    "artifact_type": {"const": "watchdog_decision"},
    "schema_version": {"const": "v0.1"},
    "schema_ref": {"const": "schemas/watchdog_decision.v0.1.schema.json"},
    "decision_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "decision": {
      "enum": [
        "record_health",
        "renew_lease",
        "mark_stale",
        "move_to_dead_letter",
        "retry_later",
        "escalate_operator",
        "block_autostart"
      ]
    },
    "reason": {"type": "string", "minLength": 1, "maxLength": 512},
    "decided_at": {"type": "string", "minLength": 1, "maxLength": 64},
    "source": {"type": "string", "minLength": 1, "maxLength": 128},
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "schema", "observation", "observed_at", "digest"],
      "properties": {
        "record_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "schema": {"type": "string", "minLength": 1, "maxLength": 128},
        "observation": {"type": "string", "minLength": 1, "maxLength": 128},
        "observed_at": {"type": "string", "minLength": 1, "maxLength": 64},
        "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "admission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_digest", "admission_digest", "allowed", "outcome"],
      "properties": {
        "request_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "admission_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "allowed": {"type": "boolean"},
        "outcome": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    },
    "affected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "event_id", "trigger_id", "inbox_item_name"],
      "properties": {
        "operation_id": {"type": ["string", "null"], "maxLength": 128},
        "event_id": {"type": ["string", "null"], "maxLength": 128},
        "trigger_id": {"type": ["string", "null"], "maxLength": 128},
        "inbox_item_name": {"type": ["string", "null"], "maxLength": 256}
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truth_layer",
        "supervisor",
        "policy_authority",
        "domain_authority",
        "execution_authority"
      ],
      "properties": {
        "truth_layer": {"const": "sclite"},
        "supervisor": {"const": "rexecop"},
        "policy_authority": {"const": "govengine"},
        "domain_authority": {"type": "string", "minLength": 1, "maxLength": 128},
        "execution_authority": {"const": "rexecop"}
      }
    },
    "manual_recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_ref", "scope", "human_signoff", "reason"],
      "properties": {
        "actor_ref": {"type": "string", "minLength": 1, "maxLength": 128},
        "scope": {"type": "string", "minLength": 1, "maxLength": 256},
        "human_signoff": {"type": "boolean"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 512}
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "maxLength": 256}
    }
  }
}
