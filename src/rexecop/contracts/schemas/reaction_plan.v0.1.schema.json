{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sclite.dev/reaction_plan.v0.1.schema.json",
  "title": "SCLite Reaction Plan v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "schema_version", "schema_ref", "reaction_id", "created_at", "profile_ref", "rule_ref", "outcome", "intent_ref", "child_operation_id", "reason", "context", "admission", "links"],
  "properties": {
    "artifact_type": {"const": "reaction_plan"},
    "schema_version": {"const": "v0.1"},
    "schema_ref": {"const": "schemas/reaction_plan.v0.1.schema.json"},
    "reaction_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "created_at": {"type": "string", "minLength": 1, "maxLength": 64},
    "profile_ref": {"$ref": "#/$defs/profile_ref"},
    "rule_ref": {
      "type": "object", "additionalProperties": false, "required": ["id", "digest"],
      "properties": {"id": {"type": "string", "minLength": 1, "maxLength": 128}, "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
    },
    "outcome": {"enum": ["run_intent", "retry_intent", "escalate", "no_op"]},
    "intent_ref": {"type": ["string", "null"], "maxLength": 128},
    "child_operation_id": {"type": ["string", "null"], "maxLength": 128},
    "reason": {"type": "string", "minLength": 1, "maxLength": 512},
    "context": {
      "type": "object", "additionalProperties": false,
      "required": ["depth", "reaction_count", "visited_rule_digests", "idempotency_key"],
      "properties": {
        "depth": {"type": "integer", "minimum": 0, "maximum": 32},
        "reaction_count": {"type": "integer", "minimum": 0, "maximum": 1024},
        "visited_rule_digests": {"type": "array", "maxItems": 1024, "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
        "idempotency_key": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "admission": {
      "type": "object", "additionalProperties": false, "required": ["status", "decision", "decision_id"],
      "properties": {
        "status": {"enum": ["not_applicable", "pending", "admitted", "blocked"]},
        "decision": {"type": ["string", "null"], "maxLength": 64},
        "decision_id": {"type": ["string", "null"], "maxLength": 128}
      }
    },
    "links": {
      "type": "object", "additionalProperties": false, "required": ["observation", "finding"],
      "properties": {"observation": {"$ref": "#/$defs/link"}, "finding": {"$ref": "#/$defs/link"}}
    }
  },
  "$defs": {
    "profile_ref": {
      "type": "object", "additionalProperties": false, "required": ["id", "version", "digest"],
      "properties": {"id": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}, "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
    },
    "descriptor": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_type", "schema_version", "schema_ref", "canonicalization", "algorithm", "digest", "canonical_bytes"],
      "properties": {
        "artifact_type": {"type": "string"}, "schema_version": {"type": "string"}, "schema_ref": {"type": "string"},
        "canonicalization": {"type": "string"}, "algorithm": {"const": "sha256"}, "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "canonical_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "link": {"type": "object", "additionalProperties": false, "required": ["descriptor"], "properties": {"descriptor": {"$ref": "#/$defs/descriptor"}}}
  }
}
